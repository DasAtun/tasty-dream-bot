generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int      @id @default(autoincrement())
  telegramId        BigInt   @unique
  language          String   @default("es")
  energy            Int      @default(30)
  lastEnergyReset   DateTime @default(now())
}
